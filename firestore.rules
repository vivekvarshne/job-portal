rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      // Use exists() to handle new/missing user documents safely
      return isAuthenticated() 
          && exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
          && getUserData().role == role;
    }
    
    function isAdmin() {
      return hasRole('admin');
    }
    
    function isVendor() {
      return hasRole('vendor');
    }
    
    // Limited Debug: Read-only access for transition
    function isDebugRead() {
      return isAuthenticated() && request.time < timestamp.date(2026, 5, 7);
    }

    // --- Collection Rules ---

    // Jobs: Publicly readable, writeable by Admin
    match /jobs/{jobId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Users: Users read/write their own profile. Admins have full access.
    match /users/{userId} {
      allow read: if request.auth.uid == userId || isAdmin() || isDebugRead();
      allow write: if request.auth.uid == userId || isAdmin();
    }
    
    // Janseva Requests: 
    match /janseva_requests/{requestId} {
      // Anyone can create (guests allowed). 
      // Validate: Initial status must be Pending & no vendor assigned yet.
      // If logged in, studentUid must match.
      allow create: if request.resource.data.status == "Pending" 
                    && request.resource.data.vendorId == null
                    && (!isAuthenticated() || request.resource.data.studentUid == request.auth.uid);
      
      // Isolated Read: Owner, Assigned Vendor, or Admin
      allow read: if isAdmin() 
                  || (isVendor() && resource.data.vendorId == request.auth.uid) 
                  || (isAuthenticated() && resource.data.studentUid == request.auth.uid)
                  || isDebugRead();
                  
      // Isolated Update: Admin or Assigned Vendor
      allow update: if isAdmin() 
                    || (isVendor() && resource.data.vendorId == request.auth.uid);
                    
      allow delete: if isAdmin();
    }
    
    // Public Collections
    match /plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
