rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (request.auth.token.email == "v753400@gmail.com" || request.auth.token.email == "V753400@gmail.com");
    }

    // Jobs collection
    match /jobs/{jobId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow write: if request.auth.uid == userId || isAdmin();
    }
    
    // Ads collection
    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Janseva Requests
    match /janseva_requests/{requestId} {
      allow create: if true;
      allow read, update, delete: if isAdmin() || (isAuthenticated() && resource.data.studentUid == request.auth.uid);
    }
    
    // Catch-all for other collections
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
