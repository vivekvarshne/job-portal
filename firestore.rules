rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Read access for everyone to published jobs
    match /jobs/{jobId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // User roles (future proofing)
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
  }
}
