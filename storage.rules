rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Public read access for advertisements and job posters
    match /ads/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "v753400@gmail.com";
    }

    match /job-posters/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "v753400@gmail.com";
    }

    match /notifications/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "v753400@gmail.com";
    }

    // Janseva Requests and Profiles (Auth required)
    match /janseva_requests/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    match /profile-images/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
